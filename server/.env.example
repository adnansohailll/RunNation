# PostgreSQL connection settings (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hello_world
DB_USER=postgres
DB_PASSWORD=your_password_here

# Server port (local development only; unused on Vercel)
PORT=3001

# Used by scripts/geocode-runs.js to turn meetup_location/address_intersection
# into latitude/longitude. Needs the Geocoding API enabled.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Production / hosted Postgres (Vercel Postgres, Neon, Supabase, etc.)
# When set, this takes priority over the DB_* vars above.
# Vercel's Postgres marketplace integrations (Supabase, Neon) inject this as
# POSTGRES_URL automatically — DATABASE_URL also works if you set it yourself.
# Set this in the Vercel project's Environment Variables — do not put real
# credentials in this file or commit a .env file.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Secret used to sign/verify login JWTs. Required. Use a long random string
# (e.g. `openssl rand -hex 32`) and keep it out of version control.
JWT_SECRET=change_this_to_a_long_random_string

# Used once by scripts/init-schema.js to seed the first super admin account.
# Only needed for that one run — safe to remove afterwards.
# Wrap the password in double quotes if it contains a # (dotenv otherwise
# treats everything after an unquoted # as a comment).
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD="change_this_password"
SUPER_ADMIN_NAME=Super Admin

# Base URL of the deployed client, used to build the login link inside
# club-admin assignment emails (e.g. https://yourapp.com). Defaults to the
# local Vite dev server if unset.
APP_URL=http://localhost:5173

# SMTP settings used to email a user when they're assigned as a club admin
# (routes/clubs.js POST /:id/admins). Works with any SMTP account — Gmail
# (use an App Password, not your regular password), Outlook, or your
# domain's mail host. If left unset, the notification is just logged to the
# server console instead of emailed.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM=RunsDB <you@example.com>
